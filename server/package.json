{
  "name": "school-manager-admin",
  "version": "1.0.0",
  "description": "Backend registro elettronico scolastico",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "kill": "lsof -ti:3000 | xargs kill -9 2>/dev/null; echo '✅ Porta 3000 libera'",
    "restart": "npm run kill && npm run dev",
    "migration:generate": "tsx scripts/generate-migration.ts",
    "migration:run": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^9.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
